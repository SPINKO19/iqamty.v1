# Pin the Firebase iOS SDK version to prevent CocoaPods dependency loops
$FirebaseSDKVersion = '11.5.0'

# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronous off-main-thread.
install! 'cocoapods', :deterministic_uuids => false

# --- FLUTTER START ---
prepare_path = File.join('Flutter', 'podhelper.rb')
if File.exist?(prepare_path)
  load prepare_path
else
  puts "Warning: Flutter/podhelper.rb not found"
end
# --- FLUTTER END ---

target 'Runner' do
  # Use static linkage for better reliability with Firebase on CI/CD
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
    end
  end
end
