# Pin the Firebase iOS SDK version to prevent CocoaPods dependency loops
$FirebaseSDKVersion = '11.10.0'

# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronous off-main-thread.
install! 'cocoapods', :deterministic_uuids => false

# --- FLUTTER START ---
# Load podhelper.rb from the Flutter SDK to ensure relative paths are resolved correctly.
if ENV['FLUTTER_ROOT']
  load File.join(ENV['FLUTTER_ROOT'], 'packages', 'flutter_tools', 'bin', 'podhelper.rb')
else
  # Fallback for local development or if FLUTTER_ROOT is not in environment
  prepare_path = File.join('Flutter', 'podhelper.rb')
  if File.exist?(prepare_path)
    load prepare_path
  else
    # Try to find it via flutter configuration as a last resort
    flutter_root = `flutter config --machine`.match(/"flutterRoot":\s*"([^"]+)"/)[1] rescue nil
    if flutter_root
      load File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper.rb')
    else
      puts "Warning: Could not find Flutter SDK path"
    end
  end
end
# --- FLUTTER END ---

target 'Runner' do
  # Use static linkage for better reliability with Firebase on CI/CD
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
    end
  end
end
